PORT=3000
NODE_ENV=development

# Generate a strong random value for real use, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Optional: point the SQLite file at a persistent disk/volume mount on your
# host (e.g. Render's Disk feature) instead of the app's own directory, which
# most platforms wipe on every redeploy. Leave unset for local development.
# DATABASE_PATH=/var/data/student_portal.sqlite
