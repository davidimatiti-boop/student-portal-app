PORT=3000
NODE_ENV=development

# Generate a strong random value for real use, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Turso (hosted SQLite-compatible database). Create a free database at
# https://app.turso.tech, then copy its connection URL and an auth token here.
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=replace-with-your-turso-auth-token
